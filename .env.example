# PromptThrift MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# Optional: API key for cloud-based compression (uses LLM to summarize).
# If not set, local heuristic compression is used (still effective, just less precise).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: Ollama settings for Gemma 4 local LLM compression
# Install Ollama (https://ollama.com) + run: ollama pull gemma4:4b
# PROMPTTHRIFT_OLLAMA_MODEL=gemma4:4b
# PROMPTTHRIFT_OLLAMA_URL=http://localhost:11434

# Optional: Default model for cost estimation
# PROMPTTHRIFT_DEFAULT_MODEL=claude-sonnet-4.6

# Optional: Server transport (stdio or streamable_http)
# PROMPTTHRIFT_TRANSPORT=stdio

# Optional: Port for streamable_http transport
# PROMPTTHRIFT_PORT=8000
